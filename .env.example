# ─────────────────────────────────────────────────────
# Portfolio Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────

# Formspree form ID (get it from https://formspree.io)
# After creating a form, your ID is the last segment of the endpoint URL
# e.g. https://formspree.io/f/xknqqwzv → ID is xknqqwzv
VITE_FORMSPREE_ID=your_formspree_form_id_here
